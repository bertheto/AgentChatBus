{
  "repository": {
    "type": "git",
    "url": "https://github.com/Killea/AgentChatBus.git"
  },
  "name": "agentchatbus",
  "displayName": "AgentChatBus",
  "description": "AgentChatBus client for VS Code",
  "version": "0.1.69",
  "icon": "resources/bus_128.png",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "agentchatbus.provider",
        "label": "AgentChatBus Local Server"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentchatbus",
          "title": "AgentChatBus",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "agentchatbus": [
        {
          "id": "agentchatbus.setup",
          "name": "Setup AgentChatBus",
          "icon": "$(gear)",
          "when": "!agentchatbus:serverReady"
        },
        {
          "id": "agentchatbus.threads",
          "name": "Threads",
          "icon": "$(comment-discussion)",
          "when": "agentchatbus:serverReady"
        },
        {
          "id": "agentchatbus.mcpLogs",
          "name": "MCP Server Logs",
          "icon": "$(terminal)",
          "when": "agentchatbus:serverReady"
        },
        {
          "id": "agentchatbus.settings",
          "name": "Management",
          "icon": "$(gear)",
          "when": "agentchatbus:serverReady"
        },
        {
          "id": "agentchatbus.agents",
          "name": "Agents",
          "icon": "$(robot)",
          "visibility": "collapsed",
          "when": "agentchatbus:serverReady"
        }
      ]
    },
    "configuration": {
      "title": "AgentChatBus",
      "properties": {
        "agentchatbus.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:39765",
          "description": "AgentChatBus server URL"
        },
        "agentchatbus.autoStartBusServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the AgentChatBus server if it is not running."
        },
        "agentchatbus.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable to use for starting the server."
        }
      }
    },
    "commands": [
      {
        "command": "agentchatbus.refreshThreads",
        "title": "Refresh Threads",
        "icon": "$(refresh)"
      },
      {
        "command": "agentchatbus.refreshAgents",
        "title": "Refresh Agents",
        "icon": "$(refresh)"
      },
      {
        "command": "agentchatbus.toggleAgentFilter",
        "title": "Toggle Filter (Last Hour)",
        "icon": "$(filter)"
      },
      {
        "command": "agentchatbus.openFullLog",
        "title": "Open Full Logs",
        "icon": "$(link-external)"
      },
      {
        "command": "agentchatbus.clearMcpLogs",
        "title": "Clear Logs",
        "icon": "$(clear-all)"
      },
      {
        "command": "agentchatbus.filterThreads",
        "title": "Filter Threads",
        "icon": "$(filter)"
      },
      {
        "command": "agentchatbus.openThread",
        "title": "Open Thread"
      },
      {
        "command": "agentchatbus.archiveThread",
        "title": "Archive Thread",
        "icon": "$(archive)"
      },
      {
        "command": "agentchatbus.unarchiveThread",
        "title": "Unarchive Thread",
        "icon": "$(history)"
      },
      {
        "command": "agentchatbus.deleteThread",
        "title": "Delete Thread",
        "icon": "$(trash)"
      },
      {
        "command": "agentchatbus.changeThreadStatus",
        "title": "Change Status...",
        "icon": "$(edit)"
      },
      {
        "command": "agentchatbus.copyThreadId",
        "title": "Copy Thread ID",
        "icon": "$(copy)"
      },
      {
        "command": "agentchatbus.retrySetup",
        "title": "Retry Setup",
        "icon": "$(refresh)"
      },
      {
        "command": "agentchatbus.showMcpStatus",
        "title": "MCP Integration Status",
        "icon": "$(plug)"
      },
      {
        "command": "agentchatbus.configureCursorMcp",
        "title": "Configure Cursor MCP",
        "icon": "$(symbol-event)"
      },
      {
        "command": "agentchatbus.openCursorMcpConfig",
        "title": "Open Cursor MCP Config",
        "icon": "$(go-to-file)"
      },
      {
        "command": "agentchatbus.stopServer",
        "title": "Force Restart MCP Service",
        "icon": "$(sync)"
      },
      {
        "command": "agentchatbus.stopServerPending",
        "title": "Force Restart In Progress",
        "icon": "$(sync~spin)"
      },
      {
        "command": "agentchatbus.openWebConsole",
        "title": "Open Web Console",
        "icon": "$(browser)"
      },
      {
        "command": "agentchatbus.serverSettings",
        "title": "Server Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentchatbus.refreshThreads",
          "when": "view == agentchatbus.threads",
          "group": "navigation@1"
        },
        {
          "command": "agentchatbus.filterThreads",
          "when": "view == agentchatbus.threads",
          "group": "navigation@2"
        },
        {
          "command": "agentchatbus.refreshAgents",
          "when": "view == agentchatbus.agents",
          "group": "navigation@1"
        },
        {
          "command": "agentchatbus.toggleAgentFilter",
          "when": "view == agentchatbus.agents",
          "group": "navigation@2"
        },
        {
          "command": "agentchatbus.stopServer",
          "when": "view == agentchatbus.mcpLogs && !agentchatbus:serverStopping",
          "group": "navigation@1"
        },
        {
          "command": "agentchatbus.stopServerPending",
          "when": "view == agentchatbus.mcpLogs && agentchatbus:serverStopping",
          "group": "navigation@1"
        },
        {
          "command": "agentchatbus.openFullLog",
          "when": "view == agentchatbus.mcpLogs",
          "group": "navigation@3"
        },
        {
          "command": "agentchatbus.clearMcpLogs",
          "when": "view == agentchatbus.mcpLogs",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "agentchatbus.changeThreadStatus",
          "when": "view == agentchatbus.threads",
          "group": "1_status"
        },
        {
          "command": "agentchatbus.archiveThread",
          "when": "view == agentchatbus.threads && viewItem != thread:archived",
          "group": "2_lifecycle"
        },
        {
          "command": "agentchatbus.unarchiveThread",
          "when": "view == agentchatbus.threads && viewItem == thread:archived",
          "group": "2_lifecycle"
        },
        {
          "command": "agentchatbus.copyThreadId",
          "when": "view == agentchatbus.threads",
          "group": "3_util"
        },
        {
          "command": "agentchatbus.deleteThread",
          "when": "view == agentchatbus.threads",
          "group": "4_destructive"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/**/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/node": "20.x",
    "@types/eventsource": "^1.1.15",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "eventsource": "^2.0.2"
  },
  "publisher": "AgentChatBus"
}
